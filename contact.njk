---
layout: base.njk
pageTitle: "Contact"
pageDesc: "Contact L&M Automotive Performance. Visit us at 4 John Costas Rd, Plankenburg, Stellenbosch. Call 021 883 8512 or email reception@landm.online."
activePage: contact
---

<!-- ===================== PAGE HERO ===================== -->
<section class="page-hero">
    <div class="container">
        <span class="label">We'd Love to Hear From You</span>
        <h1>Get In Touch</h1>
        <p>Book a service, ask a question, or start planning your performance build.</p>
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="sep">/</span>
            <span class="current">Contact</span>
        </nav>
    </div>
</section>

<!-- ===================== CONTACT SECTION ===================== -->
<section class="section">
    <div class="container">
        <div class="contact-grid">

            <!-- LEFT: Info -->
            <div class="contact-info animate">
                <h3>Contact Information</h3>

                <div class="contact-detail">
                    <div class="contact-detail-icon"><i class="fas fa-map-marker-alt"></i></div>
                    <div class="contact-detail-text">
                        <span class="label">Address</span>
                        <span class="value">{{ site.address }}</span>
                    </div>
                </div>

                <div class="contact-detail">
                    <div class="contact-detail-icon"><i class="fas fa-phone"></i></div>
                    <div class="contact-detail-text">
                        <span class="label">Phone</span>
                        <a href="tel:{{ site.phone | replace(' ', '') }}" class="value">{{ site.phone }}</a>
                    </div>
                </div>

                <div class="contact-detail">
                    <div class="contact-detail-icon"><i class="fas fa-envelope"></i></div>
                    <div class="contact-detail-text">
                        <span class="label">Email</span>
                        <a href="mailto:{{ site.email }}" class="value">{{ site.email }}</a>
                    </div>
                </div>

                <div class="hours-table" style="margin-top:32px;">
                    <h4>Business Hours</h4>
                    <div class="hours-row">
                        <span class="day">Monday</span>
                        <span class="time">{{ site.hours_weekdays }}</span>
                    </div>
                    <div class="hours-row">
                        <span class="day">Tuesday</span>
                        <span class="time">{{ site.hours_weekdays }}</span>
                    </div>
                    <div class="hours-row">
                        <span class="day">Wednesday</span>
                        <span class="time">{{ site.hours_weekdays }}</span>
                    </div>
                    <div class="hours-row">
                        <span class="day">Thursday</span>
                        <span class="time">{{ site.hours_weekdays }}</span>
                    </div>
                    <div class="hours-row">
                        <span class="day">Friday</span>
                        <span class="time">{{ site.hours_friday }}</span>
                    </div>
                    <div class="hours-row closed">
                        <span class="day">Saturday</span>
                        <span class="time">Closed</span>
                    </div>
                    <div class="hours-row closed">
                        <span class="day">Sunday</span>
                        <span class="time">Closed</span>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Form -->
            <div class="contact-form-wrap animate animate-delay-2">
                <h3>Send Us a Message</h3>
                <p>Fill in the form below and we'll get back to you as soon as possible.</p>

                <form id="contactForm" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate>
                    <input type="hidden" name="form-name" value="contact">
                    <p style="display:none;"><label>Don't fill this out: <input name="bot-field"></label></p>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="firstName">First Name</label>
                            <input type="text" id="firstName" name="firstName" placeholder="John" required>
                        </div>
                        <div class="form-group">
                            <label for="lastName">Last Name</label>
                            <input type="text" id="lastName" name="lastName" placeholder="Smith" required>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="john@example.com" required>
                        </div>
                        <div class="form-group">
                            <label for="phone">Phone Number</label>
                            <input type="tel" id="phone" name="phone" placeholder="082 000 0000">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="service">Service Required</label>
                        <select id="service" name="service">
                            <option value="" disabled selected>Select a service...</option>
                            {% for service in services.items %}
                            <option value="{{ service.name | lower }}">{{ service.name }}</option>
                            {% endfor %}
                            <option value="performance">Performance Build</option>
                            <option value="other">Other / General Enquiry</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="vehicle">Vehicle (Year, Make, Model)</label>
                        <input type="text" id="vehicle" name="vehicle" placeholder="e.g. 2019 VW Golf GTI">
                    </div>
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" placeholder="Tell us more about what you need..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-red" style="width:100%; justify-content:center;">
                        <i class="fas fa-paper-plane"></i> Send Message
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

<!-- ===================== MAP ===================== -->
<div class="map-section">
    <div class="map-wrap">
        <iframe
            src="https://maps.google.com/maps?q={{ site.address | urlencode }}&output=embed"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="L&M Automotive Performance location map">
        </iframe>
    </div>
</div>
