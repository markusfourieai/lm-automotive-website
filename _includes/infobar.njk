<div class="info-bar">
    <div class="container">
        <div class="info-bar-grid">
            <div class="info-bar-item">
                <div class="info-bar-icon"><i class="fas fa-map-marker-alt"></i></div>
                <div class="info-bar-text">
                    <span class="ttl">Address</span>
                    <span class="val">{{ site.address }}</span>
                </div>
            </div>
            <div class="info-bar-item">
                <div class="info-bar-icon"><i class="fas fa-phone"></i></div>
                <div class="info-bar-text">
                    <span class="ttl">Phone</span>
                    <span class="val">{{ site.phone }}</span>
                </div>
            </div>
            <div class="info-bar-item">
                <div class="info-bar-icon"><i class="fas fa-envelope"></i></div>
                <div class="info-bar-text">
                    <span class="ttl">Email</span>
                    <span class="val">{{ site.email }}</span>
                </div>
            </div>
            <div class="info-bar-item">
                <div class="info-bar-icon"><i class="fas fa-clock"></i></div>
                <div class="info-bar-text">
                    <span class="ttl">Hours</span>
                    <span class="val">Mon–Thu {{ site.hours_weekdays }} &nbsp;·&nbsp; Fri {{ site.hours_friday }}</span>
                </div>
            </div>
        </div>
    </div>
</div>
