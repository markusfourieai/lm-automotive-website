<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if pageTitle %}{{ pageTitle }} | {% endif %}L&M Automotive Performance</title>
    <meta name="description" content="{{ pageDesc if pageDesc else 'L&M Automotive Performance — Stellenbosch premier automotive performance centre.' }}">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

    {% include "nav.njk" %}

    {{ content | safe }}

    {% include "footer.njk" %}

    <script src="/js/main.js"></script>
    <script>
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", function(user) {
                if (!user) {
                    window.netlifyIdentity.on("login", function() {
                        document.location.href = "/admin/";
                    });
                }
            });
        }
    </script>
</body>
</html>
