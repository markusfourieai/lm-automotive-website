<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col">
                <img src="/images/logo.jpg" alt="L&M Automotive Performance" class="footer-logo">
                <p>{{ site.tagline }}</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul class="footer-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/about/">About Us</a></li>
                    <li><a href="/services/">Services</a></li>
                    <li><a href="/performance/">Performance</a></li>
                    <li><a href="/contact/">Contact</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Services</h4>
                <ul class="footer-links">
                    {% for service in services.items %}
                    <li><a href="/services/">{{ service.name }}</a></li>
                    {% endfor %}
                </ul>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <ul class="footer-contact-list">
                    <li><i class="fas fa-map-marker-alt"></i> {{ site.address }}</li>
                    <li><i class="fas fa-phone"></i> {{ site.phone }}</li>
                    <li><i class="fas fa-envelope"></i> {{ site.email }}</li>
                    <li><i class="fas fa-clock"></i> Mon–Thu: {{ site.hours_weekdays }}</li>
                    <li><i class="fas fa-clock"></i> Fri: {{ site.hours_friday }}</li>
                    <li><i class="fas fa-times-circle"></i> Sat–Sun: Closed</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 L&M Automotive Performance. All rights reserved.</p>
            <span class="footer-tagline">Built For Performance</span>
        </div>
    </div>
</footer>
